<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>add e remove</title>
</head>
<body>
<button id="ativar">Ativar registro</button>
<button id="desativar">Desativar registro</button>
<br><br>
<button id="principal">Botão principal</button>
<ul id="lista"></ul>
<script src="script.js"></script>
</body>
</html>


let principal = document.getElementById("principal")
let lista = document.getElementById("lista")
function registrar(){
    let item = document.createElement("li")
    item.textContent = "Clique"
    lista.appendChild(item)
}
document.getElementById("ativar").addEventListener("click", function (){
    principal.addEventListener("click", registrar)
})
document.getElementById("desativar").addEventListener("click", function (){
    principal.removeEventListener("click", registrar)
})
