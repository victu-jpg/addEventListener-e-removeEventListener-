<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>add e remove</title>
</head>
<body>
<button id="ativar">Ativar</button>
<button id="desativar">Desativar</button>
<br><br>
<input type="text" id="texto">
<p id="saida"></p>
<script src="script.js"></script>
</body>
</html>


let texto = document.getElementById("texto")
let saida = document.getElementById("saida")
function mostrar() {
    saida.textContent = texto.value
}
document.getElementById("ativar").addEventListener("click", function (){
    texto.addEventListener("keyup", mostrar);
})
document.getElementById("desativar").addEventListener("click", function (){
    texto.removeEventListener("keyup", mostrar);
})
