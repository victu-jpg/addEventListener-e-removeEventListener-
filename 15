<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>add e remove</title>
</head>
<body>
<button id="ativar">Ativar hora</button>
<button id="desativar">Desativar hora</button>
<button id="hora">Mostrar hora</button>
<p id="texto"></p>
<script src="script.js"></script>
</body>
</html>


let hora = document.getElementById("hora")
let texto = document.getElementById("texto")
function mostrarHora(){
    let agora = new Date()
    texto.textContent = agora.toLocaleTimeString()
}
document.getElementById("ativar").addEventListener("click",function(){
    hora.addEventListener("click",mostrarHora)
})
document.getElementById("desativar").addEventListener("click",function(){
    hora.removeEventListener("click",mostrarHora)
})
