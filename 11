<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>add e remove</title>
</head>
<body>
<h1 id="titulo">Clique em mim</h1>
<button id="ativar">Ativar evento</button>
<button id="desativar">Desativar evento</button>
<script src="script.js"></script>
</body>
</html>


let titulo = document.getElementById("titulo")
let ativar = document.getElementById("ativar")
let desativar = document.getElementById("desativar")
function mudarCor(){
    titulo.style.color = "red"
}
ativar.addEventListener("click", function (){
    titulo.addEventListener("click", mudarCor)
})
desativar.addEventListener("click", function (){
    titulo.removeEventListener("click", mudarCor)
})
