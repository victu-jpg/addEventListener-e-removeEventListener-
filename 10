<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>add e remove</title>
</head>
<body>
<button id="ativar">Ativar teclado</button>
    <button id="desativar">Desativar teclado</button>
    <h2>Teclas pressionadas - <span id="contador">0</span></h2>
<script src="script.js"></script>
</body>
</html>

let ativar = document.getElementById("ativar")
let desativar = document.getElementById("desativar")
let contador = document.getElementById("contador")
let quantidade = 0
function contarTeclas() {
    quantidade++;
    contador.textContent = quantidade
}
ativar.addEventListener("click", function (){
    document.addEventListener("keydown", contarTeclas)
})
desativar.addEventListener("click", function (){
    document.removeEventListener("keydown", contarTeclas)
})
